{
  "name": "@d-dash/builder",
  "version": "0.0.1",
  "description": "Fluent TypeScript SDK for building d-dash dashboards programmatically",
  "license": "LGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thienvu18/d-dash.git",
    "directory": "packages/builder"
  },
  "bugs": {
    "url": "https://github.com/thienvu18/d-dash/issues"
  },
  "homepage": "https://github.com/thienvu18/d-dash/tree/main/packages/builder#readme",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
